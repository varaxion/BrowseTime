{
  "manifest_version": 3,
  "name": "BrowseTime",
  "version": "0.1.0",
  "description": "A minimal, privacy-first browser session tracker.",
  "permissions": [
    "tabs",
    "idle",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "BrowseTime"
  }
}
